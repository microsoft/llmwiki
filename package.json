{
  "name": "llmwiki",
  "version": "0.1.2",
  "description": "A personal knowledge base where the LLM does all the maintenance",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/llmwiki.git"
  },
  "bugs": {
    "url": "https://github.com/microsoft/llmwiki/issues"
  },
  "homepage": "https://github.com/microsoft/llmwiki#readme",
  "workspaces": [
    "packages/core",
    "packages/vscode"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/vscode",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "npm run lint --workspace=packages/core && npm run lint --workspace=packages/vscode",
    "dev": "vitest watch"
  },
  "keywords": [
    "wiki",
    "knowledge-base",
    "vscode-extension",
    "llm",
    "mcp",
    "markdown"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
