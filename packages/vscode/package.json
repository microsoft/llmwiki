{
  "name": "@llmwiki/vscode",
  "displayName": "LLM Wiki",
  "description": "Interactive wiki browsing powered by LLM maintenance",
  "version": "0.1.0",
  "publisher": "llmwiki",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:wiki/index.md",
    "onCommand:llmwiki.init"
  ],
  "contributes": {
    "commands": [
      {
        "command": "llmwiki.init",
        "title": "LLM Wiki: Initialize Wiki"
      },
      {
        "command": "llmwiki.ingest",
        "title": "LLM Wiki: Ingest Source"
      },
      {
        "command": "llmwiki.query",
        "title": "LLM Wiki: Query Wiki"
      },
      {
        "command": "llmwiki.lint",
        "title": "LLM Wiki: Lint Wiki"
      },
      {
        "command": "llmwiki.status",
        "title": "LLM Wiki: Show Status"
      },
      {
        "command": "llmwiki.openPage",
        "title": "LLM Wiki: Open Page"
      },
      {
        "command": "llmwiki.refresh",
        "title": "LLM Wiki: Refresh"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "llmwiki-explorer",
          "title": "LLM Wiki",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "llmwiki-explorer": [
        {
          "id": "wikiPages",
          "name": "Wiki Pages"
        },
        {
          "id": "rawSources",
          "name": "Raw Sources"
        },
        {
          "id": "backlinks",
          "name": "Backlinks"
        },
        {
          "id": "lintFindings",
          "name": "Lint Findings"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "llmwiki.ingest",
          "when": "viewItem == rawSource",
          "group": "inline"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "rawSources",
        "contents": "No sources yet.\n[Add Source Files](command:llmwiki.ingest)"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "lint": "tsc --noEmit",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@llmwiki/shared": "*"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.4.0"
  }
}
