{
  "name": "llmwiki-vscode",
  "displayName": "LLM Wiki",
  "description": "Interactive wiki browsing powered by LLM maintenance",
  "version": "0.1.0",
  "publisher": "llmwiki",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/llmwiki",
    "directory": "packages/vscode"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:.wiki/wiki/index.md",
    "onCommand:llmwiki.init"
  ],
  "contributes": {
    "chatParticipants": [
      {
        "id": "llmwiki.wiki",
        "fullName": "LLM Wiki",
        "name": "wiki",
        "description": "Ask questions about your wiki knowledge base",
        "isSticky": true,
        "commands": [
          {
            "name": "status",
            "description": "Show wiki status and statistics"
          },
          {
            "name": "save",
            "description": "Save the previous answer as a wiki page"
          },
          {
            "name": "lint",
            "description": "Run wiki health checks and get fix suggestions"
          },
          {
            "name": "fix",
            "description": "Auto-fix wiki issues using LLM"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "llmwiki.init",
        "title": "LLM Wiki: Initialize Wiki"
      },
      {
        "command": "llmwiki.ingest",
        "title": "LLM Wiki: Ingest Source"
      },
      {
        "command": "llmwiki.query",
        "title": "LLM Wiki: Query Wiki"
      },
      {
        "command": "llmwiki.status",
        "title": "LLM Wiki: Show Status"
      },
      {
        "command": "llmwiki.openPage",
        "title": "LLM Wiki: Open Page"
      },
      {
        "command": "llmwiki.refresh",
        "title": "LLM Wiki: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "llmwiki.fix",
        "title": "LLM Wiki: Fix Issues",
        "icon": "$(wand)"
      },
      {
        "command": "llmwiki.search",
        "title": "LLM Wiki: Search Wiki",
        "icon": "$(search)"
      },
      {
        "command": "llmwiki.searchRaw",
        "title": "LLM Wiki: Search Sources",
        "icon": "$(search)"
      },
      {
        "command": "llmwiki.removeSource",
        "title": "LLM Wiki: Remove Source",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "llmwiki-explorer",
          "title": "LLM Wiki",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "llmwiki-explorer": [
        {
          "id": "entities",
          "name": "Entities"
        },
        {
          "id": "concepts",
          "name": "Concepts"
        },
        {
          "id": "rawSources",
          "name": "Raw Sources",
          "canSelectMany": true
        },
        {
          "id": "backlinks",
          "name": "Backlinks"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "llmwiki.search",
          "when": "view =~ /^(entities|concepts)$/",
          "group": "navigation@1"
        },
        {
          "command": "llmwiki.searchRaw",
          "when": "view == rawSources",
          "group": "navigation@1"
        },
        {
          "command": "llmwiki.fix",
          "when": "view =~ /^(entities|concepts|rawSources)$/",
          "group": "navigation@2"
        },
        {
          "command": "llmwiki.refresh",
          "when": "view =~ /^(entities|concepts|rawSources)$/",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "llmwiki.ingest",
          "when": "viewItem == rawSource",
          "group": "inline@1"
        },
        {
          "command": "llmwiki.removeSource",
          "when": "viewItem == rawSource",
          "group": "inline@2"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "rawSources",
        "contents": "No sources yet.\n[Add Source Files](command:llmwiki.ingest)"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:prod": "node esbuild.config.mjs --production",
    "lint": "tsc --noEmit",
    "watch": "node esbuild.config.mjs --watch",
    "prepackage": "npm run build:prod",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@llmwiki/shared": "*"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.4.0"
  }
}
